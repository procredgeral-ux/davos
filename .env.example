# Railway PostgreSQL Configuration
# Copie este arquivo para .env e preencha com seus valores do Railway Dashboard

# Database Connection URLs (preencha no Railway Dashboard)
DATABASE_PUBLIC_URL="postgresql://${PGUSER}:${POSTGRES_PASSWORD}@${RAILWAY_TCP_PROXY_DOMAIN}:${RAILWAY_TCP_PROXY_PORT}/${PGDATABASE}"
DATABASE_URL="postgresql://${PGUSER}:${POSTGRES_PASSWORD}@${RAILWAY_PRIVATE_DOMAIN}:5432/${PGDATABASE}"

# PostgreSQL Settings (Railway preenche automaticamente)
PGDATA="/var/lib/postgresql/data/pgdata"
PGDATABASE="${POSTGRES_DB}"
PGHOST="${RAILWAY_PRIVATE_DOMAIN}"
PGPASSWORD="${POSTGRES_PASSWORD}"
PGPORT="5432"
PGUSER="${POSTGRES_USER}"

# Database Credentials
POSTGRES_DB="railway"
POSTGRES_PASSWORD=""
POSTGRES_USER="postgres"

# Railway Settings (obtenha no Dashboard > Variables)
RAILWAY_DEPLOYMENT_DRAINING_SECONDS="60"
RAILWAY_TCP_PROXY_DOMAIN=""
RAILWAY_TCP_PROXY_PORT=""
RAILWAY_PRIVATE_DOMAIN=""

# SSL
SSL_CERT_DAYS="820"

# Server Port (Railway define automaticamente a PORT)
PORT="8080"
